# ─── Banco de Dados ──────────────────────────────────────────────────────────
# DEV (local):
DATABASE_URL=postgresql+asyncpg://opme:opme_dev_secret@localhost:5432/opme
# PRODUÇÃO — adicione ?ssl=true para forçar TLS na conexão:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/opme?ssl=true

# ─── Cache / Filas ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Elasticsearch ───────────────────────────────────────────────────────────
# DEV: sem autenticação, bind em 127.0.0.1 (ver docker-compose.yml)
ELASTICSEARCH_URL=http://localhost:9200
# PRODUÇÃO: habilite xpack.security e use credenciais:
# ELASTICSEARCH_URL=https://user:pass@host:9200

# ─── Segurança JWT ───────────────────────────────────────────────────────────
# OBRIGATÓRIO: string aleatória de pelo menos 64 caracteres
# Gere com: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=SUBSTITUA-POR-STRING-ALEATORIA-DE-64-CHARS-OU-MAIS

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here

# ─── URL base para QR Code / links de verificação ────────────────────────────
# DEV:
API_BASE_URL=http://localhost:8000
# PRODUÇÃO:
# API_BASE_URL=https://api.seudominio.com.br

# ─── Ingest API (RPA/robôs) ──────────────────────────────────────────────────
# Token opcional para autenticar robôs que enviam cotações
INGEST_API_KEY=
